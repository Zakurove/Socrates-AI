PORT=4000
DATABASE_URL=postgresql://localhost:5432/socrates_ai
# Required. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters of random hex/base64. Server refuses to boot in production otherwise.
SESSION_SECRET=replace-with-crypto-randomBytes-32-hex
OPENAI_API_KEY=sk-replace-me
CORS_ORIGIN=http://localhost:4000

# Real-time voice (Gemini Live). Both must be set to enable AI Conversation mode.
GOOGLE_AI_API_KEY=
FEATURE_AI_PRACTICE_REAL=

# Per-user daily AI spend cap in USD. Default $5. Lowering is safe.
AI_DAILY_SPEND_CAP_USD=5

# Community Library — invites (optional)
# If RESEND_API_KEY is empty, invite emails are NOT sent; the API still
# returns an inviteUrl the owner can share manually.
RESEND_API_KEY=
EMAIL_FROM=Socrates AI <noreply@socratesai.app>
APP_URL=http://localhost:4000

# Admins are promoted by explicit SQL only:
#   UPDATE users SET is_admin = true WHERE email = 'you@example.com';
# The previous ADMIN_EMAILS auto-promotion path was a privilege-escalation
# vector on DB resets and has been removed.

# Dev / E2E only. When set in non-production, disables auth/report/general
# rate limiters so Playwright can register many users without tripping 429.
# Leave UNSET in production.
RATE_LIMIT_DISABLED=
